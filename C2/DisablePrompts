--We need to remove prompts being able to be clicked by the prisoners. this local script will do just that
--Add this in the StarterPlayerScripts
--dont worry if the script looks different from the one in the video tutorial, I had to update it because the previous version in the video was a little inconsistent.
local Players = game:GetService("Players")
local player = Players.LocalPlayer
if player.Team.Name ~= "Prisoners" then
	return
end
local function hidePrompt(character)
	local root = character:WaitForChild("HumanoidRootPart")
	local prompt = root:WaitForChild("CatchPrompt")
	prompt.Enabled = false
end
for _, otherPlayer in ipairs(Players:GetPlayers()) do
	if otherPlayer.Character then
		hidePrompt(otherPlayer.Character)
	end
	otherPlayer.CharacterAdded:Connect(hidePrompt)
end
