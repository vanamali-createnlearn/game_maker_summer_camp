local function updateCatchPrompt(player, character)
	local root = character:WaitForChild("HumanoidRootPart")

	local prompt = root:FindFirstChild("CatchPrompt")

	if player.Team == prisonerTeam then
		if not prompt then
			prompt = Instance.new("ProximityPrompt")
			prompt.Name = "CatchPrompt"
			prompt.ActionText = "Catch"
			prompt.ObjectText = "Prisoner"
			prompt.MaxActivationDistance = 8
			prompt.HoldDuration = 0
			prompt.RequiresLineOfSight = false
			prompt.Parent = root
		end
	else
		if prompt then
			prompt:Destroy()
		end
	end
end
